theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 11
text = "□ 第一周期
  H  氢  1  IA   非金属  天蓝色  8张
  He 氦  2  0    稀有气体 近白色  6张

□ 第二周期
  Li 锂  3  IA   金属  灰色    6张
  Be 铍  4  IIA  金属  灰色    6张
  B  硼  5  IIIA 准金属 亮黄色  6张
  C  碳  6  IVA  非金属 亮黄色  6张
  N  氮  7  VA   非金属 紫色    6张
  O  氧  8  VIA  非金属 深蓝色  8张
  F  氟  9  VIIA 非金属 浅绿色 10张
  Ne 氖 10  0    稀有气体 近白色 6张

□ 第三周期
  Na 钠 11  IA   金属  灰色    6张
  Mg 镁 12  IIA  金属  灰色    6张
  Al 铝 13  IIIA 金属  灰色    6张
  Si 硅 14  IVA  准金属 亮黄色  6张
  P  磷 15  VA   非金属 浅粉色  6张
  S  硫 16  VIA  非金属 亮黄色  8张
  Cl 氯 17  VIIA 非金属 浅绿色 10张
  Ar 氩 18  0    稀有气体 近白色 6张"
autowrap_mode = 3

[node name="HelpCardsCol2" type="Label" parent="HelpPage_Cards" unique_id=759215029]
layout_mode = 0
offset_left = 310.0
offset_top = 40.0
offset_right = 580.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 11
text = "□ 第四周期
  K  钾 19  IA    金属  灰色    6张
  Ca 钙 20  IIA   金属  灰色    6张
  —以下为副族(各4张)—
  Cr 铬 24  VIB   金属  灰色    4张
  Mn 锰 25  VIIB  金属  灰色    4张
  Fe 铁 26  VIII  金属  灰色    4张
  Co 钴 27  VIII  金属  灰色    4张
  Ni 镍 28  VIII  金属  灰色    4张
  Cu 铜 29  IB    金属  灰色    4张
  Zn 锌 30  IIB   金属  灰色    4张
  —主族—
  Br 溴 35  VIIA  非金属 棕色   10张

□ 排除的第四周期元素
Sc(钪) Ti(钛) V(钒)
Ga(镓) Ge(锗) As(砷)
Se(硒) Kr(氪)
以上8种暂不加入牌库

□ 牌库统计
172张
= 卤族 ×10×3 = 30
+ H/O/S ×8×3 = 24
+ 主族 ×6×15 = 90
+ 副族 ×4×7 = 28"
autowrap_mode = 3

[node name="HelpCardsCol3" type="Label" parent="HelpPage_Cards" unique_id=1152783033]
layout_mode = 0
offset_left = 590.0
offset_top = 40.0
offset_right = 860.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 11
text = "□ 元素族属速查
IA族: H, Li, Na, K
IIA族: Be, Mg, Ca
IIIA族: B, Al
IVA族: C, Si
VA族: N, P
VIA族: O, S
VIIA族(卤族): F, Cl, Br
0族(稀有气体): He, Ne, Ar
副族分布:
VIB: Cr   VIIB: Mn
VIII: Fe, Co, Ni
IB: Cu   IIB: Zn

□ 双原子分子元素
可以2张同元素X₂出牌:
H₂ / N₂ / O₂ / F₂ / Cl₂

□ 不可化合组合
  ✗ F + Cl   卤族互化禁止
  ✗ F + Br   卤族互化禁止
  ✗ Cl + Br  卤族互化禁止
卤族只能与金属/
非卤族非金属化合
"
autowrap_mode = 3

[node name="HelpCardsCol4" type="Label" parent="HelpPage_Cards" unique_id=125653456]
layout_mode = 0
offset_left = 870.0
offset_top = 40.0
offset_right = 1120.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 11
text = "□ 特殊规则速查
· 溢出化合物
  牌数≥玩家数时免疫所有接牌
  (包括族炸！)
  → 打出后直接轮到下家
· 上限弃牌
  手牌达上限时必须选1张弃置
  不能正常跳过抽牌
  选1张牌→弃置→标记⏸通过
· 卤族互化禁止
  F/Cl/Br互相不可化合
  仅能与金属/非卤族化合
· 族炸冷却
  打出族炸后进入冷却❄
  必须打出化合物解除
· 族炸接炸
  顺时针询问接更大族炸
  冷却中的玩家不能接炸

□ 出牌流程速览
① 点击选中手牌(黄高亮)
② 选牌型: 单质/化合物/族炸
③ 化合物→为元素选化合价
   确认→GCD验证→打出
④ 出牌完成→牌权轮转
跳过: 未达上限时可选跳过
上限: 选1张弃置→强制跳过
"
autowrap_mode = 3

