text = "■ 游戏规则介绍"
horizontal_alignment = 1

[node name="HelpRulesCol1" type="Label" parent="HelpPage_Rules" unique_id=1355946936]
layout_mode = 0
offset_left = 30.0
offset_top = 40.0
offset_right = 300.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 12
text = "□ 游戏目标与流程
率先打光所有手牌即为胜利。
顺时针轮转出牌，每次出牌
必须比桌面牌更大。
无法出牌时可「跳过」
(抽1张，手牌达上限时不可跳过)
N-1人连续跳过→牌权移交
下一人→新一轮自由出牌。
图标: ◄牌权  ❄族炸冷却
      ⏸已跳过

□ 牌型一：单质 ELEMENT
· 1张任意元素卡牌
· 或 2张同元素双原子分子
  (H₂/N₂/O₂/F₂/Cl₂)
· 原子序数和越小牌越大
· 例: He | O₂ | Fe | Br | K

□ 牌型二：化合物 COMPOUND
· ≥2种不同元素
· 化合价可配平
· 2元素GCD最简比确认张数
· 金属优先正价，非金属负价
· 3+元素需恰好1张且电荷=0
· 禁止卤族互化
  F/Cl/Br不可互相化合
· 例: NaCl | Al₂O₃ | KBr
       CaO | NaF | FeCl₂"
autowrap_mode = 3

[node name="HelpRulesCol2" type="Label" parent="HelpPage_Rules" unique_id=1210377472]
layout_mode = 0
offset_left = 310.0
offset_top = 40.0
offset_right = 580.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 12
text = "□ 牌型三：族炸 CLAN BOMB
· 同族≥2张不同元素
· 3张>2张（数量多者大）
· 打出后族炸冷却(❄)
· 需打出化合物解除冷却，期间不能出族炸
· 例: H+Li(IA族2张)
       He+Ne+Ar(0族3张)
       Fe+Co+Ni(VIII族3张)

□ 比大小规则
优先: 族炸 > 化合物 > 单质
同牌型: 原子序数和 → 小=大
  (序数和越小→牌力越强)
平局: 原子质量和 → 大=弱

□ 接牌规则
桌面空 → 自由出牌任意牌型
桌面单质 → 接更大单质/族炸
桌面化合物 → 接更大化合物/族炸
溢出化合物(牌数≥玩家数)
  → 免疫接牌（包括族炸）

□ 接炸规则
族炸打出→顺时针询问所有
其他玩家是否接更大族炸
接炸者成为新owner
跳过者抽1张牌，标记⏸（可达上限弃牌）
接炸期间只能出族炸！
所有非owner已pass→
桌面清空，owner自由出牌"
autowrap_mode = 3

[node name="HelpRulesCol3" type="Label" parent="HelpPage_Rules" unique_id=433668409]
layout_mode = 0
offset_left = 590.0
offset_top = 40.0
offset_right = 860.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 12
text = "□ 手牌上限规则
上限 = min(玩家数 × 4, 18)
  · 4人局: 上限16张
  · 5人局: 上限18张(截断)
  · 6~8人局: 上限18张

□ 上限弃牌规则
手牌达上限时：
  必须选择1张手牌弃置
  不能正常跳过抽牌
  弃牌后标记⏸并轮转牌权
  手牌降至上限以下后
  恢复正常跳过/出牌操作

□ 卤族元素特殊规则
F、Cl、Br三种卤族元素
互相之间不可化合！
卤族只能与金属或其他
非金属化合形成化合物
禁止: F+Cl | F+Br | Cl+Br
允许: Na+F → NaF
      Ca+Cl → CaCl₂
      Fe+Br → FeBr₂"
autowrap_mode = 3

[node name="HelpRulesCol4" type="Label" parent="HelpPage_Rules" unique_id=2102326282]
layout_mode = 0
offset_left = 870.0
offset_top = 40.0
offset_right = 1120.0
offset_bottom = 585.0
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_font_sizes/font_size = 12
text = "□ 操作流程详解
① 选择手牌
   点击选中(黄色高亮)
   可多选，再次点击取消
② 选择牌型
  单质 / 化合物 / 族炸
③ 化合物专属
  为元素选化合价
  金属正价/非金属负价
  确认→GCD验证比例
④ 出牌完成→牌权轮转
跳过: 未达上限时可跳过
      抽1张→标记⏸→轮转
上限弃牌: 选1张弃置→跳过

□ 牌库配置
总牌数: 172张
28种元素(前四周期)
卤族 F/Cl/Br ×10 = 30张
H/O/S 各×8 = 24张
主族其余 15种×6 = 90张
副族 7种×4 = 28张

□ 注意要点
· 稀有气体(He/Ne/Ar)不化合
· 族炸必须不同元素同族
· 接炸时冷却玩家不能出炸
· 冷却需化合物才能解除
· 溢出化合物免疫族炸
· 任一手牌降至0立即获胜"
autowrap_mode = 3

